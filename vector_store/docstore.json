0\u5c55104\u573a\u6bd4\u8d5b\uff0c\u672c\u5c4a\u8d5b\u4e8b\u8fd8\u8fce\u6765\u7ea6\u65e6\u3001\u4e4c\u5179\u522b\u514b\u65af\u5766\u3001\u4f5b\u5f97\u89d2\u3001\u5e93\u62c9\u7d22\u56db\u652f\u9996\u6b21\u767b\u4e0a\u4e16\u754c\u676f\u6b63\u8d5b\u821e\u53f0\u7684\u65b0\u519b\uff0c\u5341\u4e8c\u652f\u5c0f\u7ec4\u5b8c\u6574\u5206\u7ec4\u60c5\u51b5\u4e3aA\u7ec4\u4e1c\u9053\u4e3b\u58a8\u897f\u54e5\u642d\u914d\u5357\u975e\u3001\u97e9\u56fd\u3001\u6377\u514b\uff0cB\u7ec4\u4e1c\u9053\u4e3b\u52a0\u62ff\u5927\u5bf9\u9635\u6ce2\u9ed1\u3001\u5361\u5854\u5c14\u3001\u745e\u58eb\uff0cC\u7ec4\u96c6\u7ed3\u4e94\u661f\u5df4\u897f\u3001\u4e0a\u5c4a\u4e16\u754c\u676f\u9ed1\u9a6c\u6469\u6d1b\u54e5\u3001\u6d77\u5730\u4e0e\u82cf\u683c\u5170\uff0cD\u7ec4\u4e1c\u9053\u4e3b\u7f8e\u56fd\u540c\u5df4\u62c9\u572d\u3001\u6fb3\u5927\u5229\u4e9a\u3001\u571f\u8033\u5176\u4ea4\u624b\uff0cE\u7ec4\u62e5\u6709\u56db\u51a0\u738b\u5fb7\u56fd\u3001\u65b0\u519b\u5e93\u62c9\u7d22\u3001\u975e\u6d32\u52b2\u65c5\u79d1\u7279\u8fea\u74e6\u548c\u5384\u74dc\u591a\u5c14\uff0cF\u7ec4\u5305\u542b\u65e0\u5195\u4e4b\u738b\u8377\u5170\u3001\u4e9a\u6d32\u9876\u5c16\u5f3a\u961f\u65e5\u672c\u3001\u745e\u5178\u4e0e\u7a81\u5c3c\u65af\uff0cG\u7ec4\u7531\u6bd4\u5229\u65f6\u3001\u57c3\u53ca\u3001\u4f0a\u6717\u548c\u5927\u6d0b\u6d32\u72ec\u82d7\u65b0\u897f\u5170\u7ec4\u6210\uff0cH\u7ec4\u6c47\u805a2", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 382, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "615711c1-29d9-41f2-b5fe-afc297e612e2": {"__data__": {"id_": "615711c1-29d9-41f2-b5fe-afc297e612e2", "embedding": null, "metadata": {"file_name": "new.docx"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "1ad63499-9ed0-425b-aeb2-c73df42a555d", "node_type": "4", "metadata": {"file_name": "new.docx"}, "hash": "4ac201b17e89bcb25d59f8acb68bd2981819ffd4e6311bbb7974d71a9861cd24", "class_name": "RelatedNodeInfo"}, "2": {"n