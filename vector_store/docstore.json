1\u4e00\u4f17\u5e74\u8f7b\u5929\u624d\uff0c\u8eab\u4f53\u5bf9\u6297\u4e0e\u5feb\u901f\u51b2\u51fb\u80fd\u529b\u4eae\u773c\uff0c\u66fe\u57281966\u5e74\u65a9\u83b7\u4e16\u754c\u676f\u51a0\u519b\uff0c\u65e0\u5195\u4e4b\u738b\u8377\u5170\u575a\u6301\u5168\u653b\u5168\u5b88\u4f20\u7edf\uff0c\u8303\u6234\u514b\u7a33\u56fa\u540e\u9632\u7ebf\uff0c\u6574\u5957\u653b\u9632\u4f53\u7cfb\u5b8c\u6574\uff0c\u591a\u6b21\u95ef\u5165\u4e16\u754c\u676f\u51b3\u8d5b\u5374\u59cb\u7ec8\u65e0\u7f18\u51a0\u519b\uff1b\u4e9a\u6d32\u53c2\u8d5b\u961f\u4f0d\u91cc\u65e5\u672c\u7efc\u5408\u5b9e\u529b\u4f4d\u5c45\u4e9a\u6d32\u9996\u4f4d\uff0c\u961f\u5185\u5927\u91cf\u7403\u5458\u6548\u529b\u6b27\u6d32\u4e94\u5927\u8054\u8d5b\uff0c\u6210\u719f\u4f20\u63a7\u4f53\u7cfb\u8ba9\u7403\u961f\u5177\u5907\u51b2\u51fb\u516b\u5f3a\u7684\u6f5c\u529b\uff0c\u97e9\u56fd\u7531\u5b59\u5174", "mimetype": "text/plain", "start_char_idx": 981, "end_char_idx": 1323, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "8348e356-8696-4c61-85d6-0bd817d89b8b": {"__data__": {"id_": "8348e356-8696-4c61-85d6-0bd817d89b8b", "embedding": null, "metadata": {"file_name": "new.docx"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "1ad63499-9ed0-425b-aeb2-c73df42a555d", "node_type": "4", "metadata": {"file_name": "new.docx"}, "hash": "4ac201b17e89bcb25d59f8acb68bd2981819ffd4e6311bbb7974d71a9861cd24", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "eb374cbb-b06f-4da7-ae97-bb6ded53da45", "node_type": "1", "metadata": {"file_name": "new.docx"}, "hash": "2c74d9ac9fbecdd0f0335d06a53f1fe9bf74f236ce3243a6eea71dc6e57c9756", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u5458\u6548\u529b\u6b27\u6d32\u4e94\u5927\u8054\u8d5b\uff0c\u6210\u719f\u4f20\u63a7\u4f53\u7cfb\u8ba9\u7403\u961f\u5177\u5907\u51b2\u51fb\u516b\u5f3a\u7684\u6f5c\u529b\uff0c\u97e9\u56fd\u7531\u5b59\u5174\u615c\u9886\u8854\uff0c\u9ad8\u5f3a\u5ea6\u8dd1\u52a8\u4e0e\u524d\u573a\u903c\u62a2\u662f\u7403\u961f\u6807\u5fd7\u6027\u6253\u6cd5\uff0c2002\u5e74\u672c\u571f\u4e16\u754c\u676f\u66fe\u95ef\u5165\u56db\u5f3a\uff0c\u4f0a\u6717\u3001\u6c99\u7279\u3001\u6fb3\u5927\u5229\u4e9a\u7b49\u4e9a\u6d32\u961f\u4f0d\u4e5f\u5177\u5907\u5404\u81ea\u72ec\u7279\u6218\u672f\u98ce\u683c\uff0c\u800c\u6469\u6d1b\u54e5\u3001\u585e\u5185\u52a0\u5c14\u3001\u79d1\u7279\u8fea\u74e6\u7b49\u975e\u6d32\u52b2\u65c5\u8eab\u4f53\u7d20\u8d28\u51fa\u4f17\u3001\u53cd\u51fb\u901f\u5ea6\u8fc5\u731b\uff0c\u4e4c\u62c9\u572d\u3001\u54e5\u4f26\u6bd4\u4e9a\u3001\u5384\u74dc\u591a\u5c14\u7b49\u5357\u7f8e\u7403\u961f\u517c\u5177\u624e\u5b9e\u6280\u672f\u4e0e\u5f3a\u786c\u5bf9\u6297\uff0c\u632a\u5a01\u3001\u745e\u58eb\u3001\u6bd4\u5229\u65f6\u7b49\u6b27\u6d32\u4e2d\u6e38\u7403\u961f\u540c\u6837\u62e5\u6709\u660e\u661f\u7403\u5458\uff0c\u5177\u5907\u5728\u5c0f\u7ec4\u8d5b\u5236\u9020\u51b7\u95e8\u7684\u5b9e\u529b\uff0c\u56db\u652f\u4e16\u754c\u676f\u65b0\u519b\u5219\u627f\u8f7d\u5404\u81ea\u5927\u6d32\u8db3\u7403\u7684\u5168\u65b0\u5e0c\u671b\uff0c\u4e3a\u672c\u5c4a\u6269\u519b\u540e\u7684\u4e16\u754c\u676f\u589e\u6dfb\u4e86\u66f4\u591a\u672a\u77e5\u770b\u70b9\u4e0e\u65b0\u9c9c\u6d3b\u529b\u3002", "mimetype": "text/plain", "start_char_idx": 1289, "end_char_idx": 1538, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "bac865d9-cdd8-4c63-87d8-5c46be5610f0": {"__data__": {"id_": "bac865d9-cdd8-4c63-87d8-5c46be5610f0", "embedding": null, "metadata": {"file_name": "test.txt"}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "21af5350-0999-432b-8119-ae06956c3953", "node_type": "4", "metadata": {"file_name": "test.txt"}, "hash": "fe22acfae8a6d7cb88d472755e6c45c81abd136eb840ef55abc11373720ef2eb", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u5f20\u8001\u5e08\u