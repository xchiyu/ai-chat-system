d32\u6709\u97e9\u56fd\u3001\u5361\u5854\u5c14\u3001\u6fb3\u5927\u5229\u4e9a\u3001\u4f0a\u6717\u3001\u6c99\u7279\u3001\u7ea6\u65e6\u3001\u4e4c\u5179\u522b\u514b\u65af\u57668\u652f\u7403\u961f\uff0c\u4e2d\u5317\u7f8e\u4e1c\u9053\u4e3b\u58a8\u897f\u54e5\u3001\u52a0\u62ff\u5927\u3001\u7f8e\u56fd\u5360\u636e3\u4e2a\u5e2d\u4f4d\uff0c\u5927\u6d0b\u6d32\u4ec5\u65b0\u897f\u5170\u4e00\u652f\u7403\u961f\u664b\u7ea7\uff1b\u4f17\u591a\u593a\u51a0\u70ed\u95e8\u7403\u961f\u5404\u5177\u7279\u8272\uff0c\u536b\u5195\u51a0\u519b\u963f\u6839\u5ef7\u624b\u63e13\u6b21\u4e16\u754c\u676f\u51a0\u519b\u8363\u8a89\uff0c\u961f\u5185\u6838\u5fc3\u662f\u4f20\u5947\u7403\u661f\u6885\u897f\uff0c\u642d\u914d\u8fea\u739b\u5229\u4e9a\u3001\u963f\u5c14\u74e6\u96f7\u65af\u7b49\u5b9e\u529b\u6d3e\u7403\u5458\uff0c\u7403\u961f\u653b\u9632\u5747\u8861\u4e14\u5927\u8d5b\u7ecf\u9a8c\u5145\u8db3\uff0c\u662f\u672c\u5c4a\u593a\u51a0\u6700\u5927\u70ed\u95e8\u4e4b\u4e00\uff0c\u6cd5\u56fd\u961f\u66fe\u62ff\u4e0b1998\u30012018\u4e24\u5c4a\u4e16\u754c\u676f\u51a0\u519b\uff0c\u59c6\u5df4\u4f69\u3001\u683c\u5217\u5179\u66fc\u3001\u695a\u963f\u6885\u5c3c\u7b49\u5929\u624d\u7403\u5458\u6784\u5efa\u8d77\u8db3\u575b\u9876\u5c16\u7684\u9635\u5bb9\u6df1\u5ea6\uff0c\u51b2\u51fb\u529b\u4e0e\u524d\u573a\u901f\u5ea6\u4f18\u52bf\u5341\u5206\u7a81\u51fa\uff0c\u4e94\u661f\u5df4\u897f\u62e5\u6709\u8db3\u575b\u6700\u591a\u7684\u4e94\u6b21\u4e16\u754c\u676f\u51a0\u519b\uff0c\u5185\u9a6c\u5c14\u3001\u7ef4\u5c3c\u4fee\u65af\u3001\u7f57\u5fb7\u91cc\u6208\u7ec4\u6210\u534e\u4e3d\u524d\u573a\uff0c\u6851\u5df4\u5f0f\u7ec6\u817b\u6280\u672f\u4e0e\u8fb9\u8def\u7a81\u7834\u80fd\u529b\u72ec\u4e00\u6863\uff0c\u8461\u8404\u7259\u7531C\u7f57", "mimetype": "text/plain", "start_char_idx": 662, "end_char_idx": 1012, "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "eb374cbb-b06f-4da7-ae97-bb6ded53da45": {"__data__": {"id_": "eb374cbb-b06f-4da7-ae97-bb6ded53da45", "embedding": null, "metadata": {"file_name"